# 1. 패키지 및 의존성 (용량이 매우 크고 언제든 재설치 가능)
node_modules
.pnpm-store

# 2. 빌드 결과물 (배포 시 새로 생성됨)
dist
dist-ssr

# 3. 환경 변수 (보안을 위해 절대 Git에 올리면 안 됨)
.env
.env.*.local

# 4. 로그 및 캐시 파일 (버전 관리 불필요)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tsbuildinfo
.eslintcache
.prettiercache

# 5. OS 및 에디터 설정 (개발자 개인의 환경 설정이므로 팀원과 공유 불필요)
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
